RISCV_ARCH := rv32im
RISCV_ABI := ilp32
RISCV_MCMODEL := medlow
BREATH_TPU_SOC_DEMO_OPT ?= -O2

TARGET = breath_tpu_soc_demo

TPU_RUNTIME_USE_MMIO ?= 0
TPU_RUNTIME_USE_EXPORTED_PARAMS_Q8_8 ?= 0
TPU_RUNTIME_PARAM_POOL_PRELOADED ?= 0
BREATH_TPU_SOC_DEMO_USE_UART ?= 1
BREATH_TPU_SOC_USE_CPU_FRONTEND ?= 0
BREATH_TPU_SOC_USE_HW_CNN_FRONTEND ?= 0
BREATH_CPU_FRONTEND_USE_SW_CNN ?= 0
BREATH_CPU_FRONTEND_PREPROCESS_RAW ?= 0

CFLAGS += $(BREATH_TPU_SOC_DEMO_OPT)
CFLAGS += -D CPU_FREQ_MHZ=50
CFLAGS += -D TPU_RUNTIME_USE_MMIO=$(TPU_RUNTIME_USE_MMIO)
CFLAGS += -D TPU_RUNTIME_USE_EXPORTED_PARAMS_Q8_8=$(TPU_RUNTIME_USE_EXPORTED_PARAMS_Q8_8)
CFLAGS += -D TPU_RUNTIME_PARAM_POOL_PRELOADED=$(TPU_RUNTIME_PARAM_POOL_PRELOADED)
CFLAGS += -D BREATH_TPU_SOC_DEMO_USE_UART=$(BREATH_TPU_SOC_DEMO_USE_UART)
CFLAGS += -D BREATH_TPU_SOC_USE_CPU_FRONTEND=$(BREATH_TPU_SOC_USE_CPU_FRONTEND)
CFLAGS += -D BREATH_TPU_SOC_USE_HW_CNN_FRONTEND=$(BREATH_TPU_SOC_USE_HW_CNN_FRONTEND)
CFLAGS += -D BREATH_CPU_FRONTEND_USE_SW_CNN=$(BREATH_CPU_FRONTEND_USE_SW_CNN)
CFLAGS += -D BREATH_CPU_FRONTEND_PREPROCESS_RAW=$(BREATH_CPU_FRONTEND_PREPROCESS_RAW)

C_SRCS := $(wildcard *.c)
